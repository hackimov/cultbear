APP_NAME=CultBear
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# SSL (Let's Encrypt + nginx): в local — самоподписанный сертификат; в production — certbot.
# Первый домен в SSL_DOMAINS = имя каталога в /etc/letsencrypt/live/ и CN для самоподписанного до выдачи сертификата.
# Для прода: SSL_DOMAINS=cu1tbear.ru,www.cu1tbear.ru,xn--90aoee1ao8d.xn--p1ai
SSL_DOMAINS=cu1tbear.local,cultbear.local
SSL_EMAIL=admin@cu1tbear.ru
SSL_CERTBOT_CONTAINER=cultbear-certbot
SSL_NGINX_CONTAINER=cultbear-nginx
SSL_CERTBOT_WEBROOT=/var/www/certbot
DOCKER_SOCKET_PATH=/var/run/docker.sock

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_FORWARD_PORT=5432
DB_DATABASE=cultbear
DB_USERNAME=cultbear
DB_PASSWORD=change_me

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_FORWARD_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ru-central-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=

DADATA_TOKEN=
DADATA_SECRET=

TOCHKA_API_URL=https://enter.tochka.com/uapi
TOCHKA_API_KEY=
TOCHKA_CUSTOMER_CODE=
TOCHKA_MERCHANT_ID=
TOCHKA_PAYMENT_MODES=card,sbp
TOCHKA_SUCCESS_REDIRECT_URL="${APP_URL}/payment/success"
TOCHKA_FAIL_REDIRECT_URL="${APP_URL}/payment/failed"
TOCHKA_WEBHOOK_PUBLIC_KEY_PEM=
TOCHKA_WEBHOOK_JWK_PUBLIC=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@cultbear.local

VITE_APP_NAME="${APP_NAME}"
